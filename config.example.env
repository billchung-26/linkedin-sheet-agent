# Copy to .env and fill in your values
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project → Enable "Google Sheets API"
# 2. Create OAuth 2.0 credentials (Desktop app)
# 3. Download JSON and save as credentials.json in this folder

# Your Google Sheet ID (from the sheet URL: .../d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_sheet_id_here

# Sheet name (tab name) that contains the LinkedIn links
SHEET_NAME=Sheet1

# Column letter that has LinkedIn profile URLs (e.g. A, B, F)
URL_COLUMN=A

# Row number where data starts (header row is often 1, data from 2)
DATA_START_ROW=2

# Optional: specify which columns to write results to.
# If not set, the script writes to the two columns right after URL_COLUMN.
# COMPANY_COLUMN=I
# TITLE_COLUMN=J
